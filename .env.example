#!/usr/bin/env bash
# Exir Pooyan Environment Configuration (.env.example)
# Copy to .env and fill with actual values

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=secure_postgres_password
PG_DATABASE=exir_pooyan

# ============================================================================
# Directus BaaS Configuration
# ============================================================================
DIRECTUS_URL=http://localhost:8055
DIRECTUS_ADMIN_EMAIL=admin@exirpooyan.com
DIRECTUS_ADMIN_PASSWORD=admin_secure_password
DIRECTUS_ADMIN_TOKEN=your-directus-admin-token

# ============================================================================
# Keycloak Authentication Configuration
# ============================================================================
KEYCLOAK_URL=http://localhost:8080/realms/exir
KEYCLOAK_CLIENT_ID=exir-pooyan-client
KEYCLOAK_CLIENT_SECRET=keycloak-client-secret
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ============================================================================
# Application Server Configuration
# ============================================================================
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=True
APP_ENVIRONMENT=development

# ============================================================================
# NiceGUI Configuration
# ============================================================================
NICEGUI_HOST=0.0.0.0
NICEGUI_PORT=8080
NICEGUI_RELOAD=True

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=structured
LOG_OUTPUT=console

# ============================================================================
# Security & CORS
# ============================================================================
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:8080,http://localhost:3000
JWT_SECRET_KEY=your-super-secret-jwt-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================================
# Integration Provider Endpoints
# ============================================================================
ODOO_URL=http://odoo:8069/jsonrpc
ODOO_DB=exir_production
ODOO_USERNAME=exir_system_user
ODOO_PASSWORD=odoo_password

VIKUNJA_URL=http://vikunja:3456/api
VIKUNJA_API_KEY=vikunja-api-key

N8N_URL=http://n8n:5678
N8N_WEBHOOK_URL=http://n8n:5678/webhook/trigger

# ============================================================================
# Email Configuration
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@exirpooyan.com
SMTP_PASSWORD=email_app_password

# ============================================================================
# File Storage Configuration
# ============================================================================
FILE_UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=.pdf,.xlsx,.docx,.png,.jpg

# ============================================================================
# OpenAI / Embedding Configuration (Optional)
# ============================================================================
OPENAI_API_KEY=sk-xxx-your-api-key
EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# Redis Configuration (Optional - for caching/queuing)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ============================================================================
# Circuit Breaker Configuration
# ============================================================================
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3
